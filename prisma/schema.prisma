// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// User settings and preferences
model Settings {
  id                    String   @id @default(cuid())
  currency              String   @default("USD")
  theme                 String   @default("light")
  pin                   String?
  biometricEnabled      Boolean  @default(false)
  // Email Reports
  email                 String?
  emailReportFrequency  String   @default("none") // "none", "weekly", "monthly"
  lastReportSent        DateTime?
  // Notifications
  notificationsEnabled  Boolean  @default(false)
  billReminderDays      Int      @default(3) // Days before bill due
  // Gamification
  totalPoints           Int      @default(0)
  currentStreak         Int      @default(0)
  longestStreak         Int      @default(0)
  lastActivityDate      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Categories for income and expense
model Category {
  id        String   @id @default(cuid())
  name      String
  type      String   // "income" or "expense"
  icon      String   @default("📄")
  // AI learning - track how often this category is used with certain keywords
  keywords  String?  // JSON array of associated keywords
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, type])
}

// Transactions (income and expenditure)
model Transaction {
  id              String   @id @default(cuid())
  type            String   // "income", "expenditure" (changed from "expense")
  expenditureType String?  @default("regular") // "regular" or "capital" (for expenditure only)
  amount          Float
  category        String
  date            String   // ISO date string YYYY-MM-DD
  note            String?
  receipt         String?  // Base64 encoded image or URL
  // Receipt Scanner fields
  merchantName     String?  // Extracted merchant name
  receiptDate      String?  // Extracted date from receipt
  receiptTotal     Float?  // Extracted total from receipt
  isFromReceipt    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([type])
  @@index([category])
  @@index([date])
  @@index([expenditureType])
}

// Monthly budgets per category
model Budget {
  id        String   @id @default(cuid())
  category  String
  month     String   // Month name like "January", "February"
  limit     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, month])
}

// Savings goals
model Goal {
  id        String   @id @default(cuid())
  name      String
  target    Float
  current   Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Recurring bills/expenses
model Recurring {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  category  String
  lastDate  String?  // Last date this was added as a transaction
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Gamification - Savings Challenges
model Challenge {
  id           String   @id @default(cuid())
  name         String
  description  String
  type         String   // "52week", "nospend", "custom", "monthly"
  target       Float    // Target amount or days
  current      Float    @default(0)
  startDate    String   // ISO date
  endDate      String?  // ISO date (null for ongoing)
  status       String   @default("active") // "active", "completed", "failed", "paused"
  points       Int      @default(0) // Points earned when completed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Gamification - Achievements/Badges
model Achievement {
  id           String   @id @default(cuid())
  type         String   // "streak", "savings", "budget", "first", "milestone"
  name         String
  description  String
  icon         String   @default("🏆")
  points       Int      @default(0)
  unlockedAt   DateTime?
  createdAt    DateTime @default(now())
  
  @@unique([type, name])
}

// AI Categorization Learning
model CategoryLearning {
  id           String   @id @default(cuid())
  category     String
  keyword      String
  count        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([category, keyword])
  @@index([keyword])
}

// Loans - Money loaned out (not an expense, but reduces available money)
model Loan {
  id              String   @id @default(cuid())
  borrowerName    String   // Name of person/entity borrowing
  amount          Float    // Original loan amount
  remainingAmount Float    // Amount still owed
  dateLoaned      String   // ISO date when loan was given
  dueDate         String?  // Expected repayment date
  status          String   @default("active") // "active", "partially_paid", "paid", "written_off"
  note            String?  // Additional notes
  // Repayment tracking
  repayments      LoanRepayment[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([borrowerName])
}

// Loan Repayments - Track partial repayments
model LoanRepayment {
  id          String   @id @default(cuid())
  loanId      String
  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount      Float    // Amount repaid
  date        String   // ISO date of repayment
  note        String?
  createdAt   DateTime @default(now())

  @@index([loanId])
}
